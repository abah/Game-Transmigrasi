{
  "hosting": {
    "site": "gametransmigrasi",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase/**",
      ".git/**",
      ".gitignore",
      "node_modules/**",
      "android/**",
      "ios/**",
      "www/**",
      "package.json",
      "package-lock.json",
      "capacitor.config.json",
      "README.md",
      "*.log",
      "**/*.sh",
      "**/*.bat",
      "**/*.exe",
      "**/*.cmd"
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=604800"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=86400"
          }
        ]
      }
    ]
  }
}
